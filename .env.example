# Database
DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus_core?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# LLM Providers (add only those you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Security
API_KEY_SECRET=
WEBHOOK_SIGNING_KEY=

# Provisioning (Dokploy-managed client OpenClaw instances)
DOKPLOY_API_KEY=
DOKPLOY_URL=https://panel.fomo.com.ar
DOKPLOY_PROJECT_ID=FB8vO-CROjg6mBFpnsuyU

# OpenClaw Integration (service-to-service auth for OpenClaw Manager ↔ fomo-core)
OPENCLAW_INTERNAL_KEY=

# ─── ManyChat Webhook Integration ────────────────────────────────────────────
# Secret for validating ManyChat webhook requests
MANYCHAT_WEBHOOK_SECRET=

# Agent ID for Marketpaper customer service (used by ManyChat webhook)
MARKETPAPER_AGENT_ID=

# ─── HubSpot CRM Integration ─────────────────────────────────────────────────
# HubSpot Private App access token for CRM operations
HUBSPOT_ACCESS_TOKEN=

# ─── Lead Reactivation Campaign ──────────────────────────────────────────────
# API key for protecting reactivation campaign endpoints
REACTIVATION_API_KEY=

# WAHA instance URL for sending reactivation WhatsApp messages
# Example: http://localhost:3003 or https://waha.fomo.com.ar
REACTIVATION_CAMPAIGN_WAHA_INSTANCE=

# WAHA session name for reactivation (default: "default")
REACTIVATION_WAHA_SESSION=default

# Project ID for storing reactivation schedules (default: "system")
REACTIVATION_PROJECT_ID=system

# LLM model for generating reactivation messages (default: claude-3-5-sonnet-20241022)
REACTIVATION_MODEL=claude-3-5-sonnet-20241022

# ─── WAHA WhatsApp Integration ───────────────────────────────────────────────
# Default WAHA instance URL (fallback if not specified per-integration)
WAHA_DEFAULT_URL=http://localhost:3003

# WAHA API key for authentication (if WAHA is configured with API key)
WAHA_API_KEY=

# Public URL of this Nexus Core instance (for webhook callbacks)
NEXUS_PUBLIC_URL=https://api.fomo.com.ar

# ─── Approval Notifier (Telegram + Dashboard Link) ───────────────────────────
# Bot token from @BotFather — used to push approval notifications to operators.
# Leave empty to disable the Telegram dashboard-link notifier (in-app still fires).
TELEGRAM_APPROVAL_BOT_TOKEN=

# Fallback chat_id when a project has no per-project override in
# project.metadata.approvalNotifier.telegram.chatId.
TELEGRAM_APPROVAL_DEFAULT_CHAT_ID=

# Base URL of the operator dashboard — used to build the "Ver y aprobar" link
# that both the Telegram message and the in-app notification point to.
# Example: https://dashboard.fomo.app
APPROVAL_DASHBOARD_BASE_URL=
