# Database
DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus_core?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# LLM Providers (add only those you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Security
API_KEY_SECRET=
WEBHOOK_SIGNING_KEY=

# Provisioning (Docker container lifecycle for client OpenClaw instances)
DOCKER_SOCKET_PATH=/var/run/docker.sock
PROVISIONING_PORT_RANGE_START=19000
PROVISIONING_PORT_RANGE_END=19999
CLIENT_TEMPLATES_PATH=./templates

# OpenClaw Integration (service-to-service auth for OpenClaw Manager ↔ fomo-core)
OPENCLAW_INTERNAL_KEY=
