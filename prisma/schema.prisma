generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pgcrypto]
}

// ─── Projects ───────────────────────────────────────────────────

model Project {
  id          String   @id
  name        String
  description String?
  environment String   @default("development")
  owner       String
  tags        String[]
  configJson  Json     @map("config_json")
  metadata    Json?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions         Session[]
  promptLayers     PromptLayer[]
  usageRecords     UsageRecord[]
  memoryEntries    MemoryEntry[]
  approvalRequests ApprovalRequest[]
  scheduledTasks   ScheduledTask[]
  contacts         Contact[]
  webhooks         Webhook[]
  files            File[]
  agents               Agent[]
  channelIntegrations  ChannelIntegration[]
  secrets              Secret[]
  apiKeys              ApiKey[]
  mcpServerInstances   MCPServerInstance[]
  skillInstances       SkillInstance[]
  campaigns            Campaign[]
  campaignTemplates    CampaignTemplate[]
  clients              Client[]
  agentRuns            AgentRun[]
  inAppNotifications   InAppNotification[]
  members              ProjectMember[]

  @@map("projects")
}

// ─── Project Members (RBAC) ────────────────────────────────────
//
// Human operators with access to a project, scoped by role.
// Orthogonal to ApiKey: members represent dashboard users, API keys
// represent machine callers. Middleware (requireProjectRole) checks
// membership only when the request carries an `x-user-email` header;
// Master / project API keys bypass.

enum ProjectRole {
  owner      // full access: create/delete agents, members, billing
  operator   // create/edit agents, reply chats, resolve approvals; cannot manage members or billing
  viewer     // read-only: lists, inbox, traces, cost; cannot create anything
}

model ProjectMember {
  id         String      @id @default(cuid())
  projectId  String      @map("project_id")
  userId     String      @map("user_id")
  email      String
  role       ProjectRole
  invitedBy  String?     @map("invited_by")
  acceptedAt DateTime?   @map("accepted_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@unique([projectId, email])
  @@index([userId])
  @@map("project_members")
}

// ─── In-App Notifications ──────────────────────────────────────
//
// Persistent in-dashboard notifications (approval requests, system alerts, etc.).
// Stored in DB (not only in-memory/SSE) so operators see pending notifications
// if they reconnect after being offline.

model InAppNotification {
  id        String    @id @default(cuid())
  projectId String    @map("project_id")
  userId    String?   @map("user_id")      // null = for any member of the project
  kind      String                         // e.g. 'approval_requested'
  payload   Json                           // { approvalId, agentName, leadName, actionSummary, riskLevel, ... }
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, readAt])
  @@map("in_app_notifications")
}

// ─── Contacts ───────────────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")

  name        String
  displayName String?  @map("display_name")

  phone       String?
  email       String?
  telegramId  String?  @map("telegram_id")
  slackId     String?  @map("slack_id")

  role        String?                          // 'customer' | 'staff' | 'owner' | null
  tags        String[]                         // e.g. ["vip", "wholesale", "prospect"]
  timezone    String?
  language    String   @default("es")
  metadata    Json?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions    Session[]

  @@unique([projectId, phone])
  @@unique([projectId, email])
  @@unique([projectId, telegramId])
  @@unique([projectId, slackId])
  @@index([projectId])
  @@map("contacts")
}

// ─── Sessions ───────────────────────────────────────────────────

model Session {
  id        String    @id
  projectId String    @map("project_id")
  contactId String?   @map("contact_id")
  agentId   String?   @map("agent_id")
  status    String    @default("active")
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact          Contact?          @relation(fields: [contactId], references: [id])
  agent            Agent?            @relation(fields: [agentId], references: [id])
  messages         Message[]
  traces           ExecutionTrace[]
  approvalRequests ApprovalRequest[]

  @@index([projectId, status])
  @@index([contactId])
  @@index([agentId])
  @@map("sessions")
}

// ─── Messages ───────────────────────────────────────────────────

model Message {
  id        String   @id
  sessionId String   @map("session_id")
  role      String
  content   String
  mediaUrls String[] @default([]) @map("media_urls")
  toolCalls Json?    @map("tool_calls")
  usage     Json?
  traceId   String?  @map("trace_id")
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

// ─── Memory Entries (pgvector) ──────────────────────────────────

model MemoryEntry {
  id             String                      @id
  projectId      String                      @map("project_id")
  agentId        String?                     @map("agent_id")
  sessionId      String?                     @map("session_id")
  scope          String                      @default("agent")
  category       String
  content        String
  embedding      Unsupported("vector(1536)")?
  importance     Float                       @default(0.5)
  accessCount    Int                         @default(0) @map("access_count")
  lastAccessedAt DateTime                    @default(now()) @map("last_accessed_at")
  createdAt      DateTime                    @default(now()) @map("created_at")
  expiresAt      DateTime?                   @map("expires_at")
  metadata       Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, category])
  @@index([projectId, importance])
  @@index([projectId, agentId])
  @@index([projectId, scope])
  @@map("memory_entries")
}

// ─── Prompt Layers ─────────────────────────────────────────────

enum PromptLayerType {
  identity
  instructions
  safety
}

model PromptLayer {
  id               String          @id
  projectId        String          @map("project_id")
  layerType        PromptLayerType @map("layer_type")
  version          Int
  content          String
  isActive         Boolean         @default(false) @map("is_active")
  createdAt        DateTime        @default(now()) @map("created_at")
  createdBy        String          @map("created_by")
  changeReason     String          @map("change_reason")
  performanceNotes String?         @map("performance_notes")
  metadata         Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, layerType, version])
  @@index([projectId, layerType, isActive])
  @@map("prompt_layers")
}

// ─── Usage Records ──────────────────────────────────────────────

model UsageRecord {
  id               String   @id
  projectId        String   @map("project_id")
  sessionId        String   @map("session_id")
  agentId          String?  @map("agent_id")
  clientId         String?  @map("client_id")
  traceId          String   @map("trace_id")
  provider         String
  model            String
  inputTokens      Int      @map("input_tokens")
  outputTokens     Int      @map("output_tokens")
  cacheReadTokens  Int      @default(0) @map("cache_read_tokens")
  cacheWriteTokens Int      @default(0) @map("cache_write_tokens")
  costUsd          Float    @map("cost_usd")
  timestamp        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@index([projectId, sessionId])
  @@index([projectId, agentId])
  @@index([projectId, clientId])
  @@map("usage_records")
}

// ─── Execution Traces ───────────────────────────────────────────

model ExecutionTrace {
  id              String    @id
  projectId       String    @map("project_id")
  sessionId       String    @map("session_id")
  promptSnapshot  Json      @map("prompt_snapshot")
  events          Json
  totalDurationMs Int       @map("total_duration_ms")
  totalTokensUsed Int       @map("total_tokens_used")
  totalCostUsd    Float     @map("total_cost_usd")
  turnCount       Int       @map("turn_count")
  status          String
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([sessionId])
  @@map("execution_traces")
}

// ─── Approval Requests ──────────────────────────────────────────

model ApprovalRequest {
  id             String    @id
  projectId      String    @map("project_id")
  sessionId      String    @map("session_id")
  toolCallId     String    @map("tool_call_id")
  toolId         String    @map("tool_id")
  toolInput      Json      @map("tool_input")
  riskLevel      String    @map("risk_level")
  status         String    @default("pending")
  requestedAt    DateTime  @default(now()) @map("requested_at")
  expiresAt      DateTime  @map("expires_at")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedBy     String?   @map("resolved_by")
  resolutionNote String?   @map("resolution_note")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId, status])
  @@map("approval_requests")
}

// ─── Scheduled Tasks ────────────────────────────────────────────

enum ScheduledTaskOrigin {
  static
  agent_proposed
}

enum ScheduledTaskStatus {
  proposed
  active
  paused
  rejected
  completed
  expired
}

enum ScheduledTaskRunStatus {
  pending
  running
  completed
  failed
  timeout
  budget_exceeded
}

model ScheduledTask {
  id                 String              @id
  projectId          String              @map("project_id")
  agentId            String?             @map("agent_id")
  name               String
  description        String?
  cronExpression     String              @map("cron_expression")
  taskPayload        Json                @map("task_payload")
  origin             ScheduledTaskOrigin
  status             ScheduledTaskStatus @default(proposed)
  proposedBy         String?             @map("proposed_by")
  approvedBy         String?             @map("approved_by")
  maxRetries         Int                 @default(2) @map("max_retries")
  timeoutMs          Int                 @default(300000) @map("timeout_ms")
  budgetPerRunUsd    Float               @default(1.0) @map("budget_per_run_usd")
  maxDurationMinutes Int                 @default(30) @map("max_duration_minutes")
  maxTurns           Int                 @default(10) @map("max_turns")
  maxRuns            Int?                @map("max_runs")
  runCount           Int                 @default(0) @map("run_count")
  lastRunAt          DateTime?           @map("last_run_at")
  nextRunAt          DateTime?           @map("next_run_at")
  expiresAt          DateTime?           @map("expires_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent    Agent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  runs     ScheduledTaskRun[]
  campaign Campaign?

  @@index([projectId, status])
  @@index([status, nextRunAt])
  @@index([agentId])
  @@map("scheduled_tasks")
}

model ScheduledTaskRun {
  id              String                @id
  taskId          String                @map("task_id")
  status          ScheduledTaskRunStatus @default(pending)
  startedAt       DateTime?             @map("started_at")
  completedAt     DateTime?             @map("completed_at")
  durationMs      Int?                  @map("duration_ms")
  tokensUsed      Int?                  @map("tokens_used")
  costUsd         Float?                @map("cost_usd")
  traceId         String?               @map("trace_id")
  result          Json?
  errorMessage    String?               @map("error_message")
  retryCount      Int                   @default(0) @map("retry_count")
  createdAt       DateTime              @default(now()) @map("created_at")

  task ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([status])
  @@map("scheduled_task_runs")
}

// ─── Webhooks ───────────────────────────────────────────────────

model Webhook {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  agentId     String?  @map("agent_id")

  name        String
  description String?

  triggerPrompt String  @map("trigger_prompt")
  secretEnvVar  String? @map("secret_env_var")
  allowedIps    String[] @map("allowed_ips")

  status      String   @default("active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("webhooks")
}

// ─── Agents ─────────────────────────────────────────────────────

enum AgentType {
  conversational    // Customer-facing: replies to inbound messages on channels (WhatsApp/Telegram/Slack)
  process           // Scheduled/batch: triggered by cron or batch API call
  backoffice        // Internal/copilot/manager/admin: triggered by Fomo team or owner via UI/Slack/WhatsApp-owner
}

model Agent {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")

  name        String
  description String?

  // Config
  promptConfig    Json    @map("prompt_config")     // identity, instructions, safety
  llmConfig       Json?   @map("llm_config")        // Optional per-agent LLM override (provider, model, temperature)
  toolAllowlist   String[] @map("tool_allowlist")   // Allowed tool IDs
  mcpServers      Json?   @map("mcp_servers")       // MCP server configs
  channelConfig   Json?   @map("channel_config")    // Which channels this agent uses
  modes           Json?   @map("modes")             // AgentMode[] — operating mode definitions (public/internal)

  // Limits
  maxTurns            Int     @default(10) @map("max_turns")
  maxTokensPerTurn    Int     @default(4000) @map("max_tokens_per_turn")
  budgetPerDayUsd     Float   @default(10.0) @map("budget_per_day_usd")

  // Skills
  skillIds        String[] @map("skill_ids")    // References to SkillInstance IDs

  // Type — determines who triggers the agent (channel inbound / cron / human via UI)
  type        AgentType @default(conversational)

  // Status
  status      String   @default("active")  // active, paused, disabled

  // Metadata
  metadata    Json?    @map("metadata")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions    Session[]
  campaigns      Campaign[]
  campaignSends  CampaignSend[]
  scheduledTasks ScheduledTask[]

  // Sub-Agent Relations
  managerAgentId String? @map("manager_agent_id")
  managerAgent   Agent?  @relation("SubAgentToManager", fields: [managerAgentId], references: [id])
  subAgents      Agent[] @relation("SubAgentToManager")

  @@unique([projectId, name])
  @@index([projectId, status])
  @@index([projectId, type])
  @@map("agents")
}

// ─── Agent Templates (global catalog) ───────────────────────────

model AgentTemplate {
  id                  String    @id @default(cuid())

  // Identity
  slug                String    @unique
  name                String
  description         String
  type                AgentType
  icon                String?
  tags                String[]
  isOfficial          Boolean   @default(true) @map("is_official")

  // Agent defaults (materialized by POST /projects/:id/agents/from-template)
  promptConfig        Json                                    @map("prompt_config")
  suggestedTools      String[]                                @map("suggested_tools")
  suggestedLlm        Json?                                   @map("suggested_llm")
  suggestedModes      Json?                                   @map("suggested_modes")
  suggestedChannels   String[]                                @map("suggested_channels")
  suggestedMcps       Json?                                   @map("suggested_mcps")
  suggestedSkillSlugs String[]                                @map("suggested_skill_slugs")
  metadata            Json?

  // Limits
  maxTurns            Int       @default(10)   @map("max_turns")
  maxTokensPerTurn    Int       @default(4000) @map("max_tokens_per_turn")
  budgetPerDayUsd     Float     @default(10.0) @map("budget_per_day_usd")

  // Versioning (soft — no in-place mutation)
  version             Int       @default(1)

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt      @map("updated_at")

  @@index([type])
  @@index([isOfficial])
  @@map("agent_templates")
}

// ─── Channel Integrations ───────────────────────────────────

model ChannelIntegration {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  provider  String   // 'chatwoot'
  config    Json     // Provider-specific config (e.g. Chatwoot: baseUrl, accountId, inboxId, agentBotId, apiTokenEnvVar)
  status    String   @default("active") // active | paused
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider])
  @@index([provider, status])
  @@map("channel_integrations")
}

// ─── Secrets ────────────────────────────────────────────────────

model Secret {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  key            String                          // e.g. "TELEGRAM_BOT_TOKEN", "TAVILY_API_KEY"
  encryptedValue String   @map("encrypted_value") // AES-256-GCM encrypted
  iv             String                          // Initialization vector (hex)
  authTag        String   @map("auth_tag")       // GCM auth tag (hex)
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
  @@map("secrets")
}

// ─── API Keys ────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique                   // SHA-256 hex hash — never plaintext
  prefix     String                              // first 8 chars of raw token
  name       String
  projectId  String?   @map("project_id")        // null = master key (full access)
  scopes     String[]  @default([])              // ["chat", "agents:read", "agents:write", "*"]
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("api_keys")
}

// ─── Files ──────────────────────────────────────────────────────

model File {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")

  filename         String
  originalFilename String   @map("original_filename")
  mimeType         String   @map("mime_type")
  sizeBytes        Int      @map("size_bytes")

  storageProvider  String   @map("storage_provider")
  storagePath      String   @map("storage_path")
  publicUrl        String?  @map("public_url")

  uploadedBy       String?  @map("uploaded_by")
  uploadedAt       DateTime @default(now()) @map("uploaded_at")
  expiresAt        DateTime? @map("expires_at")

  metadata         Json?

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, uploadedAt])
  @@index([projectId, mimeType])
  @@map("files")
}

// ─── MCP Server Templates ──────────────────────────────────────

model MCPServerTemplate {
  id              String   @id @default(cuid())
  name            String   @unique
  displayName     String   @map("display_name")
  description     String
  category        String   // erp, crm, productivity, communication, custom
  transport       String   // stdio | sse
  command         String?
  args            String[]
  defaultEnv      Json?    @map("default_env")
  url             String?
  toolPrefix      String?  @map("tool_prefix")
  requiredSecrets String[] @map("required_secrets")
  isOfficial      Boolean  @default(false) @map("is_official")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  instances MCPServerInstance[]

  @@index([category])
  @@map("mcp_server_templates")
}

// ─── MCP Server Instances ──────────────────────────────────────

model MCPServerInstance {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  templateId     String?  @map("template_id")
  name           String
  displayName    String?  @map("display_name")
  description    String?
  transport      String   // stdio | sse
  command        String?
  args           String[]
  envSecretKeys  Json?    @map("env_secret_keys") // { "API_KEY": "ODOO_API_KEY" } — references process.env var names
  envVars        Json?    @map("env_vars")         // { "API_KEY": "actual-value" } — direct values passed to subprocess
  url            String?
  toolPrefix     String?  @map("tool_prefix")
  status         String   @default("active") // active | paused | error
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template MCPServerTemplate? @relation(fields: [templateId], references: [id])

  @@unique([projectId, name])
  @@index([projectId, status])
  @@map("mcp_server_instances")
}

// ─── Skill Templates ──────────────────────────────────────────

model SkillTemplate {
  id                   String   @id @default(cuid())
  name                 String   @unique
  displayName          String   @map("display_name")
  description          String
  category             String   // sales, support, operations, communication

  // Composition
  instructionsFragment String   @map("instructions_fragment")  // Appended to agent's Instructions
  requiredTools        String[] @map("required_tools")         // Tool IDs needed
  requiredMcpServers   String[] @map("required_mcp_servers")   // MCP server names needed (optional)

  // Parameters schema (JSON Schema format for dashboard form generation)
  parametersSchema     Json?    @map("parameters_schema")

  // Metadata
  tags         String[]
  icon         String?                      // Lucide icon name for dashboard
  isOfficial   Boolean  @default(false) @map("is_official")
  version      Int      @default(1)
  status       String   @default("published") // draft | published | deprecated

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  instances    SkillInstance[]

  @@index([category])
  @@map("skill_templates")
}

// ─── Skill Instances ──────────────────────────────────────────

model SkillInstance {
  id                   String   @id @default(cuid())
  projectId            String   @map("project_id")
  templateId           String?  @map("template_id")         // null = custom skill
  name                 String
  displayName          String   @map("display_name")
  description          String?

  // Can override template values
  instructionsFragment String   @map("instructions_fragment")
  requiredTools        String[] @map("required_tools")
  requiredMcpServers   String[] @map("required_mcp_servers")

  // Resolved parameters (user-filled values)
  parameters           Json?

  status               String   @default("active") // active | disabled

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  project              Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template             SkillTemplate? @relation(fields: [templateId], references: [id])

  @@unique([projectId, name])
  @@index([projectId, status])
  @@map("skill_instances")
}

// ─── Campaigns ─────────────────────────────────────────────────

enum CampaignStatus {
  draft
  active
  paused
  completed
  cancelled
}

enum CampaignSendStatus {
  queued
  sent
  failed
  replied
  converted
  delivered
  unsubscribed
}

model Campaign {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  agentId          String         @map("agent_id")
  scheduledTaskId  String?        @unique @map("scheduled_task_id")
  name             String
  status           CampaignStatus @default(draft)
  template         String         // Mustache-style: "Hola {{name}}, ..."
  channel          String         // whatsapp | telegram | slack
  audienceFilter   Json           @map("audience_filter") // { tags: ["prospect"], role?: "customer" }
  audienceSource   Json?          @map("audience_source") // { kind: "static"|"hubspot-deals"|..., params: {...}, ttlHours: 24 }
  audienceCache    Json?          @map("audience_cache")  // { contacts: [...], cachedAt: ISO, expiresAt: ISO }
  scheduledFor     DateTime?      @map("scheduled_for")
  completedAt      DateTime?      @map("completed_at")
  pausedAt         DateTime?      @map("paused_at")
  resumedAt        DateTime?      @map("resumed_at")
  cancelledAt      DateTime?      @map("cancelled_at")
  metadata         Json?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent         Agent          @relation(fields: [agentId], references: [id], onDelete: Restrict)
  scheduledTask ScheduledTask? @relation(fields: [scheduledTaskId], references: [id], onDelete: SetNull)
  sends         CampaignSend[]

  @@index([projectId, status])
  @@index([agentId])
  @@map("campaigns")
}

model CampaignSend {
  id             String             @id @default(cuid())
  campaignId     String             @map("campaign_id")
  agentId        String             @map("agent_id")
  contactId      String             @map("contact_id")
  status         CampaignSendStatus @default(queued)
  variantId      String?            @map("variant_id") // null if not an A/B test
  error          String?
  sentAt         DateTime?          @map("sent_at")
  deliveredAt    DateTime?          @map("delivered_at")
  unsubscribedAt DateTime?          @map("unsubscribed_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  agent    Agent          @relation(fields: [agentId], references: [id], onDelete: Restrict)
  reply    CampaignReply?

  @@index([campaignId, status])
  @@index([campaignId, variantId])
  @@index([contactId])
  @@index([agentId])
  @@map("campaign_sends")
}

model CampaignReply {
  id               String   @id @default(cuid())
  campaignSendId   String   @unique @map("campaign_send_id")
  contactId        String   @map("contact_id")
  sessionId        String   @map("session_id")
  repliedAt        DateTime @map("replied_at")
  messageCount     Int      @default(1) @map("message_count")
  converted        Boolean  @default(false)
  conversionNote   String?  @map("conversion_note")

  campaignSend CampaignSend @relation(fields: [campaignSendId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("campaign_replies")
}

model CampaignTemplate {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  body        String
  variables   String[]
  channel     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@map("campaign_templates")
}

// ─── Clients (for cost tracking) ────────────────────────────────

model Client {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  name             String
  externalId       String?  @map("external_id")  // External CRM ID
  monthlyBudgetUSD Float?   @map("monthly_budget_usd")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
  @@index([projectId])
  @@map("clients")
}

// ─── Agent Runs (generic pipeline monitoring) ─────────────────

model AgentRun {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  externalProject String?   @map("external_project")
  runType         String    @map("run_type")
  description     String?
  status          String    @default("running") // running, done, failed, killed
  totalSteps      Int       @map("total_steps")
  currentStep     Int       @default(0) @map("current_step")
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMs      Int?      @map("duration_ms")
  metadata        Json?

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  steps   AgentRunStep[]

  @@index([projectId, status, startedAt])
  @@index([externalProject, status])
  @@index([status, startedAt])
  @@map("agent_runs")
}

// ─── Admin Audit Log ────────────────────────────────────────────

model AdminAuditLog {
  id            String   @id @default(cuid())
  actor         String   // 'mariano' | 'guille' | 'scheduled' | 'cli'
  sessionId     String?  @map("session_id")
  agentId       String?  @map("agent_id")
  toolId        String   @map("tool_id")
  inputRedacted Json     @map("input_redacted")
  approvedBy    String?  @map("approved_by")
  outcome       String   // 'success' | 'error' | 'denied'
  traceId       String?  @map("trace_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([actor, createdAt])
  @@index([toolId, createdAt])
  @@map("admin_audit_logs")
}

model AgentRunStep {
  id          String    @id @default(cuid())
  runId       String    @map("run_id")
  stepIndex   Int       @map("step_index")
  agentName   String    @map("agent_name")
  status      String    @default("pending") // pending, working, done, failed, skipped
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")
  input       String?
  output      String?
  metadata    Json?

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepIndex])
  @@index([runId, status])
  @@map("agent_run_steps")
}

// ════════════════════════════════════════════════════════════════════
// RESEARCH MODULE — Agent Observatory
// ════════════════════════════════════════════════════════════════════
//
// See NEXUS_INTELLIGENCE_PLAN.md (in fomo-core-docs) for the design.
// All tables are gated behind RESEARCH_MODULE_ENABLED feature flag at
// the route level. Access restricted to super_admin (see super-admin-guard).
//
// Two unique partial indexes are added in the migration's manual SQL
// step (not expressible in Prisma DSL) to enforce: 1 active session
// per (target | phone). Look for them in:
//   prisma/migrations/<timestamp>_add_research_module/migration.sql
//
// ────────────────────────────────────────────────────────────────────

// ─── Research Verticals ─────────────────────────────────────────────

model ResearchVertical {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  description          String?
  isActive             Boolean  @default(true) @map("is_active")
  scoringRubric        Json     @map("scoring_rubric")
  analysisInstructions String   @db.Text @map("analysis_instructions")
  minCooldownHours     Int      @default(24) @map("min_cooldown_hours")
  activeHoursStart     Int      @default(9) @map("active_hours_start")
  activeHoursEnd       Int      @default(21) @map("active_hours_end")
  createdBy            String?  @map("created_by")
  updatedBy            String?  @map("updated_by")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  probeScripts ProbeScript[]
  targets      ResearchTarget[]
  insights     IntelligenceInsight[]
  patterns     PromptPattern[]

  @@index([isActive])
  @@map("research_verticals")
}

// ─── Phone Inventory ────────────────────────────────────────────────

model ResearchPhone {
  id              String              @id @default(cuid())
  label           String              @unique
  wahaSession     String              @unique @map("waha_session")
  phoneNumber     String?             @map("phone_number")
  status          ResearchPhoneStatus @default(pending)
  identityName    String?             @map("identity_name")
  identityAvatar  String?             @map("identity_avatar")
  identityBio     String?             @map("identity_bio")
  notes           String?
  lastSeenAt      DateTime?           @map("last_seen_at")
  bannedAt        DateTime?           @map("banned_at")
  banReason       String?             @map("ban_reason")
  totalSessions   Int                 @default(0) @map("total_sessions")
  totalTurnsToday Int                 @default(0) @map("total_turns_today")
  createdBy       String?             @map("created_by")
  createdAt       DateTime            @default(now()) @map("created_at")

  sessions  ResearchSession[]
  schedules ResearchSessionSchedule[]

  @@index([status])
  @@map("research_phones")
}

enum ResearchPhoneStatus {
  pending
  active
  disconnected
  banned
  quarantined
}

// ─── Research Targets ───────────────────────────────────────────────

model ResearchTarget {
  id             String           @id @default(cuid())
  name           String
  company        String?
  phoneNumber    String           @unique @map("phone_number")
  verticalSlug   String           @map("vertical_slug")
  country        String           @default("AR")
  sourceType     TargetSourceType @map("source_type")
  sourceValue    String           @db.Text @map("source_value")
  notes          String?          @db.Text
  status         TargetStatus     @default(pending)
  priority       Int              @default(1)
  tags           String[]
  optedOutAt     DateTime?        @map("opted_out_at")
  optedOutReason String?          @map("opted_out_reason")
  dsarDeletedAt  DateTime?        @map("dsar_deleted_at")
  createdBy      String           @map("created_by")
  updatedBy      String?          @map("updated_by")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  vertical  ResearchVertical          @relation(fields: [verticalSlug], references: [slug], onDelete: Restrict)
  sessions  ResearchSession[]
  schedules ResearchSessionSchedule[]

  @@index([verticalSlug, status])
  @@index([country])
  @@index([optedOutAt])
  @@map("research_targets")
}

enum TargetStatus {
  pending
  active
  completed
  paused
  failed
  banned
}

enum TargetSourceType {
  url
  screenshot
  referral
  other
}

// ─── Probe Scripts ──────────────────────────────────────────────────

model ProbeScript {
  id               String     @id @default(cuid())
  name             String
  verticalSlug     String     @map("vertical_slug")
  level            ProbeLevel
  objective        String
  estimatedMinutes Int        @map("estimated_minutes")
  turns            Json
  waitMinMs        Int        @default(3000) @map("wait_min_ms")
  waitMaxMs        Int        @default(8000) @map("wait_max_ms")
  isOfficial       Boolean    @default(false) @map("is_official")
  isActive         Boolean    @default(true) @map("is_active")
  version          Int        @default(1)
  createdBy        String?    @map("created_by")
  updatedBy        String?    @map("updated_by")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  vertical  ResearchVertical          @relation(fields: [verticalSlug], references: [slug], onDelete: Restrict)
  sessions  ResearchSession[]
  schedules ResearchSessionSchedule[]

  @@unique([verticalSlug, name])
  @@index([level, isActive])
  @@map("probe_scripts")
}

enum ProbeLevel {
  L1_SURFACE
  L2_CAPABILITIES
  L3_ARCHITECTURE
  L4_ADVERSARIAL
  L5_LONGITUDINAL
}

// ─── Research Sessions ──────────────────────────────────────────────

model ResearchSession {
  id                  String                @id @default(cuid())
  targetId            String                @map("target_id")
  phoneId             String                @map("phone_id")
  scriptId            String                @map("script_id")
  status              ResearchSessionStatus @default(queued)
  currentTurn         Int                   @default(0) @map("current_turn")
  startedAt           DateTime?             @map("started_at")
  completedAt         DateTime?             @map("completed_at")
  failedAt            DateTime?             @map("failed_at")
  failReason          String?               @map("fail_reason")
  failCode            String?               @map("fail_code")
  retryCount          Int                   @default(0) @map("retry_count")
  notes               String?
  scheduleId          String?               @map("schedule_id")
  retentionEligibleAt DateTime?             @map("retention_eligible_at")
  triggeredBy         String?               @map("triggered_by")
  createdAt           DateTime              @default(now()) @map("created_at")

  target   ResearchTarget           @relation(fields: [targetId], references: [id], onDelete: Cascade)
  phone    ResearchPhone            @relation(fields: [phoneId], references: [id], onDelete: Restrict)
  script   ProbeScript              @relation(fields: [scriptId], references: [id], onDelete: Restrict)
  schedule ResearchSessionSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  turns    ResearchTurn[]
  analysis ResearchAnalysis?

  @@index([status])
  @@index([targetId, completedAt])
  @@index([phoneId, status])
  @@index([scheduleId])
  @@index([retentionEligibleAt])
  @@map("research_sessions")
}

enum ResearchSessionStatus {
  queued
  running
  waiting_response
  paused
  completed
  failed
  aborted
}

// ─── Research Turns ─────────────────────────────────────────────────

model ResearchTurn {
  id              String        @id @default(cuid())
  sessionId       String        @map("session_id")
  turnOrder       Int           @map("turn_order")
  direction       TurnDirection
  message         String        @db.Text
  rawMessage      String?       @db.Text @map("raw_message")
  sanitized       Boolean       @default(false)
  redactionsCount Int           @default(0) @map("redactions_count")
  timestamp       DateTime      @default(now())
  latencyMs       Int?          @map("latency_ms")
  wahaMessageId   String?       @unique @map("waha_message_id")
  isTimeout       Boolean       @default(false) @map("is_timeout")
  notes           String?

  session ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, turnOrder, direction])
  @@index([sessionId])
  @@map("research_turns")
}

enum TurnDirection {
  outbound
  inbound
}

// ─── Research Analysis ──────────────────────────────────────────────

model ResearchAnalysis {
  id                String  @id @default(cuid())
  sessionId         String  @unique @map("session_id")
  version           Int     @default(1)
  previousVersionId String? @map("previous_version_id")

  // Nivel 1 — Superficie
  agentName            String?  @map("agent_name")
  hasPresentationMenu  Boolean? @map("has_presentation_menu")
  menuType             String?  @map("menu_type")
  toneProfile          String?  @map("tone_profile")
  toneNotes            String?  @db.Text @map("tone_notes")
  usesEmoji            Boolean? @map("uses_emoji")
  responseTimeP50Ms    Int?     @map("response_time_p50_ms")
  responseTimeP95Ms    Int?     @map("response_time_p95_ms")
  hasProactiveReengage Boolean? @map("has_proactive_reengage")
  reengageTimeMs       Int?     @map("reengage_time_ms")
  languagesDetected    String[] @map("languages_detected")

  // Nivel 2 — Capabilities
  capabilityMap     Json?    @map("capability_map")
  canTakeActions    Boolean? @map("can_take_actions")
  hasRealtimeLookup Boolean? @map("has_realtime_lookup")
  dataFreshness     String?  @map("data_freshness")
  capabilityNotes   String?  @db.Text @map("capability_notes")

  // Nivel 3 — Arquitectura
  estimatedLlm          String?  @map("estimated_llm")
  llmConfidence         Int?     @map("llm_confidence")
  llmEvidenceNotes      String?  @db.Text @map("llm_evidence_notes")
  hasRag                Boolean? @map("has_rag")
  ragDomainScope        String?  @map("rag_domain_scope")
  hasFunctionCalling    Boolean? @map("has_function_calling")
  detectedTools         String[] @map("detected_tools")
  hasCrossSessionMemory Boolean? @map("has_cross_session_memory")
  systemPromptHints     String?  @db.Text @map("system_prompt_hints")
  promptStructureNotes  String?  @db.Text @map("prompt_structure_notes")

  // Nivel 4 — Adversarial
  promptInjectionResistance Int?    @map("prompt_injection_resistance")
  handlesOffensiveInput     String? @map("handles_offensive_input")
  competitorMentionPolicy   String? @map("competitor_mention_policy")
  consistencyScore          Int?    @map("consistency_score")
  hallucinationRate         String? @map("hallucination_rate")
  adversarialNotes          String? @db.Text @map("adversarial_notes")

  // Nivel 5 — Longitudinal
  changesFromPrevious String?  @db.Text @map("changes_from_previous")
  significantChanges  Boolean  @default(false) @map("significant_changes")
  regressions         String[]
  improvements        String[]

  // Scores
  scores     Json?
  scoreTotal Float? @map("score_total")

  // Best/worst
  bestTurnOrder          Int?    @map("best_turn_order")
  bestTurnText           String? @db.Text @map("best_turn_text")
  bestTurnJustification  String? @db.Text @map("best_turn_justification")
  worstTurnOrder         Int?    @map("worst_turn_order")
  worstTurnText          String? @db.Text @map("worst_turn_text")
  worstTurnJustification String? @db.Text @map("worst_turn_justification")

  // Synthesis
  keyStrengths       String[] @map("key_strengths")
  keyWeaknesses      String[] @map("key_weaknesses")
  uniqueCapabilities String[] @map("unique_capabilities")
  thingsToReplicate  String[] @map("things_to_replicate")
  thingsToAvoid      String[] @map("things_to_avoid")
  executiveSummary   String?  @db.Text @map("executive_summary")

  // LLM call metadata
  rawJson           Json
  llmModel          String   @map("llm_model")
  llmInputTokens    Int?     @map("llm_input_tokens")
  llmOutputTokens   Int?     @map("llm_output_tokens")
  llmCostUsd        Decimal? @db.Decimal(10, 6) @map("llm_cost_usd")
  llmReasoningTrace String?  @db.Text @map("llm_reasoning_trace")
  degraded          Boolean  @default(false)
  analyzedAt        DateTime @default(now()) @map("analyzed_at")

  session  ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  insights InsightSource[]
  patterns PatternSource[]

  @@index([analyzedAt])
  @@index([scoreTotal])
  @@map("research_analyses")
}

// ─── Longitudinal Schedules ─────────────────────────────────────────

model ResearchSessionSchedule {
  id         String    @id @default(cuid())
  targetId   String    @map("target_id")
  scriptId   String    @map("script_id")
  phoneId    String    @map("phone_id")
  cronExpr   String?   @map("cron_expr")
  intervalMs BigInt?   @map("interval_ms")
  jitterMs   Int       @default(7200000) @map("jitter_ms")
  isActive   Boolean   @default(true) @map("is_active")
  lastRunAt  DateTime? @map("last_run_at")
  nextRunAt  DateTime  @map("next_run_at")
  runCount   Int       @default(0) @map("run_count")
  failCount  Int       @default(0) @map("fail_count")
  createdBy  String?   @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  target   ResearchTarget    @relation(fields: [targetId], references: [id], onDelete: Cascade)
  script   ProbeScript       @relation(fields: [scriptId], references: [id], onDelete: Restrict)
  phone    ResearchPhone     @relation(fields: [phoneId], references: [id], onDelete: Restrict)
  sessions ResearchSession[]

  @@index([isActive, nextRunAt])
  @@index([targetId])
  @@map("research_session_schedules")
}

// ─── Intelligence Insights ──────────────────────────────────────────

model IntelligenceInsight {
  id             String        @id @default(cuid())
  verticalSlug   String        @map("vertical_slug")
  category       String
  title          String
  content        String        @db.Text
  evidence       String?       @db.Text
  seenInCount    Int           @default(1) @map("seen_in_count")
  status         InsightStatus @default(pending)
  rejectedReason String?       @map("rejected_reason")
  approvedBy     String?       @map("approved_by")
  approvedAt     DateTime?     @map("approved_at")
  rejectedBy     String?       @map("rejected_by")
  rejectedAt     DateTime?     @map("rejected_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  vertical ResearchVertical @relation(fields: [verticalSlug], references: [slug], onDelete: Restrict)
  sources  InsightSource[]

  @@index([verticalSlug, status])
  @@index([category])
  @@map("intelligence_insights")
}

enum InsightStatus {
  pending
  approved
  rejected
  superseded
}

model InsightSource {
  insightId  String @map("insight_id")
  analysisId String @map("analysis_id")

  insight  IntelligenceInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  analysis ResearchAnalysis    @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@id([insightId, analysisId])
  @@index([analysisId])
  @@map("insight_sources")
}

// ─── Prompt Patterns ────────────────────────────────────────────────

model PromptPattern {
  id             String        @id @default(cuid())
  verticalSlug   String        @map("vertical_slug")
  category       String
  status         PatternStatus @default(pending)
  rejectedReason String?       @map("rejected_reason")
  approvedBy     String?       @map("approved_by")
  approvedAt     DateTime?     @map("approved_at")
  rejectedBy     String?       @map("rejected_by")
  rejectedAt     DateTime?     @map("rejected_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  vertical ResearchVertical       @relation(fields: [verticalSlug], references: [slug], onDelete: Restrict)
  versions PromptPatternVersion[]
  sources  PatternSource[]
  uses     PromptPatternUse[]

  @@index([verticalSlug, status])
  @@index([category])
  @@map("prompt_patterns")
}

enum PatternStatus {
  pending
  approved
  rejected
  superseded
}

model PromptPatternVersion {
  id               String   @id @default(cuid())
  patternId        String   @map("pattern_id")
  versionNumber    Int      @map("version_number")
  patternText      String   @db.Text @map("pattern_text")
  patternVariables String[] @map("pattern_variables")
  seenInCount      Int      @default(1) @map("seen_in_count")
  avgScoreWhen     Float?   @map("avg_score_when")
  notes            String?
  isCurrent        Boolean  @default(false) @map("is_current")
  editedBy         String?  @map("edited_by")
  createdAt        DateTime @default(now()) @map("created_at")

  pattern PromptPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@unique([patternId, versionNumber])
  @@index([patternId, isCurrent])
  @@map("prompt_pattern_versions")
}

model PatternSource {
  patternId  String @map("pattern_id")
  analysisId String @map("analysis_id")

  pattern  PromptPattern    @relation(fields: [patternId], references: [id], onDelete: Cascade)
  analysis ResearchAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@id([patternId, analysisId])
  @@index([analysisId])
  @@map("pattern_sources")
}

model PromptPatternUse {
  id                String   @id @default(cuid())
  patternId         String   @map("pattern_id")
  patternVersionId  String   @map("pattern_version_id")
  agentTemplateSlug String   @map("agent_template_slug")
  insertedAt        DateTime @default(now()) @map("inserted_at")
  insertedBy        String?  @map("inserted_by")
  scoreAtInsertion  Float?   @map("score_at_insertion")
  scoreAfter        Float?   @map("score_after")
  outcome           String?

  pattern PromptPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@index([patternId])
  @@index([agentTemplateSlug])
  @@map("prompt_pattern_uses")
}

// ─── Audit Log ──────────────────────────────────────────────────────

model ResearchAuditLog {
  id         String   @id @default(cuid())
  actorEmail String   @map("actor_email")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  payload    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  at         DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorEmail, at])
  @@index([action, at])
  @@map("research_audit_log")
}
